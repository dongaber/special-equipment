    "grammy": "^1.38.2"
  },
  "devDependencies": {
    "@special-equipment/eslint-config": "workspace:*",
    "@special-equipment/typescript-config": "workspace:*",
    "@types/node": "^22.0.0",
    "eslint": "^10.3.0",
    "tsx": "^4.20.6",
    "typescript": "5.5.4"
  },
